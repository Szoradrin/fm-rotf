      "_id": "aurilf2action006",
      "_key": "!actors.items!aurilsecondform01.aurilf2action006",
      "name": "Ice Stasis (Recharge 5–6)",
      "type": "feat",
      "img": "icons/svg/mystery-man.svg",
      "system": {
        "description": { "value": "Auril targets one gem crystal within 5 feet of herself and one creature she can see within 60 feet of herself. The target must succeed on a DC 21 Charisma saving throw or become trapped in the gem crystal: the target is stunned, has total cover against attacks and other effects outside the crystal, and takes 21 (6d6) cold damage at the start of each of its turns. The trapped creature can repeat the saving throw at the end of each of its turns, escaping on a success. The gem crystal can also be destroyed (AC 18, 9 hit points, immunity to all damage except fire damage), which frees the creature without harming it.", "chat": "" },
        "source": { "book": "Icewind Dale: Rime of the Frostmaiden" },
        "activation": { "type": "action", "value": 1, "condition": "" },
        "type": { "value": "monster", "subtype": "" }
      }
